# ─── Production (Coolify + bundled PostgreSQL) ───
NODE_ENV=production
PORT=3030
HOSTNAME=0.0.0.0

# Public URLs (Coolify may inject SERVICE_FQDN_APP automatically)
APP_URL=https://campain.pixlink.ir
SERVICE_FQDN_APP=campain.pixlink.ir

# Database — POSTGRES_PASSWORD is the single source of truth (entrypoint builds DATABASE_URL).
# Do NOT set DATABASE_URL separately in Coolify unless you override POSTGRES_* vars too.
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=dashboard
POSTGRES_HOST=dashboard-postgres

# Auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
AUTH_SECRET=change-me-random-secret-min-32-chars

# App data
UPLOAD_DIR=/app/data/uploads
NEXT_PUBLIC_USE_MOCK_DATA=false

# External billboard API
BILLBOARD_API_BASE_URL=https://billboard.pixlink.ir

# ─── Local dev against production DB (via SSH tunnel) ───
# 1. On server: ssh -L 5433:127.0.0.1:5432 user@your-server
# 2. Use the tunneled port locally (do not use dashboard-postgres hostname on your machine)
# DATABASE_URL=postgres://dashboard:change-me-strong-password@127.0.0.1:5433/dashboard

# ─── Alternative: Supabase (only if DATABASE_URL is not set) ───
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
