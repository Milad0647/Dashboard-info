# ─── Production (Coolify + PostgreSQL) ───
DATABASE_URL=postgres://user:password@host:5432/dashboard
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
AUTH_SECRET=change-me-random-secret-min-32-chars

# ─── Optional: force mock data (local dev without DB) ───
NEXT_PUBLIC_USE_MOCK_DATA=false

# ─── Alternative: Supabase (if not using DATABASE_URL) ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
